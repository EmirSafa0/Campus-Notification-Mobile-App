<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <!-- Sayfanın ana yerleşimi -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="10dp">

        <!-- Üst bar: geri butonu ve ekran başlığı -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/burgundy"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp">

            <!-- Geri butonu -->
            <TextView
                android:id="@+id/btnBackReports"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Geri"
                android:textColor="@color/text_white"
                android:textSize="18sp" />

            <!-- Sayfa başlığı -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Benim Bildirimlerim"
                android:textColor="@color/text_white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center" />
        </LinearLayout>

        <!-- Kullanıcı bildirileri içinde arama alanı -->
        <EditText
            android:id="@+id/etReportSearch"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="10dp"
            android:hint="Ara..."
            android:background="@drawable/search_box"
            android:padding="10dp"
            android:inputType="text" />

        <!-- Filtre başlığı: seçili durum ve açılır menü -->
        <LinearLayout
            android:id="@+id/layoutFilterHeader"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/card_bg"
            android:gravity="center_vertical"
            android:paddingHorizontal="10dp">

            <!-- Seçili filtre durumu -->
            <TextView
                android:id="@+id/txtFilterSelected"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tümü"
                android:textSize="15sp"
                android:textColor="@color/text_primary" />

            <!-- Açılır filtre menüsü oku -->
            <ImageView
                android:id="@+id/imgFilterArrow"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_arrow_down"
                android:tint="@color/icon_burgundy" />
        </LinearLayout>

        <!-- Filtre seçeneklerinin yer aldığı açılır menü -->
        <LinearLayout
            android:id="@+id/layoutFilterOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="6dp"
            android:visibility="gone">

            <!-- Tüm bildirimler -->
            <TextView
                android:id="@+id/optionAll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:text="Tümü"
                android:textSize="15sp"
                android:textColor="@color/text_primary" />

            <!-- Açık durumundaki bildirimler -->
            <TextView
                android:id="@+id/optionOpen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:text="Açık"
                android:textSize="15sp"
                android:textColor="@color/text_primary" />

            <!-- İnceleniyor durumundaki bildirimler -->
            <TextView
                android:id="@+id/optionPending"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:text="İnceleniyor"
                android:textSize="15sp"
                android:textColor="@color/text_primary" />

            <!-- Çözüldü durumundaki bildirimler -->
            <TextView
                android:id="@+id/optionSolved"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:text="Çözüldü"
                android:textSize="15sp"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <!-- Kullanıcının bildirimlerinin listelendiği RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerReports"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="6dp" />

    </LinearLayout>

    <!-- Yeni bildirim eklemek için FloatingActionButton -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddReport"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@drawable/ic_add"
        app:backgroundTint="@color/burgundy" />

</FrameLayout>
