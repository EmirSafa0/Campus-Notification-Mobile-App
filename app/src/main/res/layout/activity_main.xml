<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/app_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ================= ÜST BAR ================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/burgundy"
            android:gravity="center_vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Kampüs Bildirimleri"
                android:textColor="@color/text_white"
                android:textStyle="bold"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tvUserShortInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hoş geldin"
                android:textColor="@color/text_white"
                android:textStyle="bold"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- ================= ANA SAYFA ================= -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ana Sayfa"
            android:textStyle="bold"
            android:textSize="22sp"
            android:textColor="@color/text_primary"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kampüsle ilgili bildirim ve güvenlik işlemlerine buradan erişebilirsin."
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp"/>

        <!-- ================= 🚨 ACİL DURUM ================= -->
        <LinearLayout
            android:id="@+id/cardEmergency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:padding="16dp"
            android:orientation="vertical"
            android:background="@drawable/emergency_card_bg"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/txtEmergencyTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚨 ACİL DURUM"
                android:textColor="@color/text_white"
                android:textStyle="bold"
                android:textSize="18sp"/>

            <TextView
                android:id="@+id/txtEmergencyDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detayları görmek için dokun"
                android:textColor="@color/text_white"
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- ================= KAMPÜS HARİTASI ================= -->
        <LinearLayout
            android:id="@+id/cardCampusMap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kampüs Haritası"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/burgundy"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sağlık ve güvenlik noktalarını harita üzerinde görüntüle."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- ================= KAMPÜSTEKİ BİLDİRİMLER ================= -->
        <LinearLayout
            android:id="@+id/cardPublicReports"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kampüsteki Bildirimler"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/burgundy"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kampüsteki bildirimleri görüntüle."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- ================= BENİM BİLDİRİMLERİM ================= -->
        <LinearLayout
            android:id="@+id/cardMyReports"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Benim Bildirimlerim"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/burgundy"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Göndermiş olduğun güvenlik bildirimlerini görüntüle."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- ================= ADMİN PANELİ (SADECE ADMIN) ================= -->
        <LinearLayout
            android:id="@+id/cardAdminPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Admin Paneli"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/burgundy"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bildirimleri ve acil durumları yönet."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- ================= PROFİL ================= -->
        <LinearLayout
            android:id="@+id/cardProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profilim"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/burgundy"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hesap bilgileri ve ayarlar."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- ================= ÇIKIŞ ================= -->
        <LinearLayout
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/burgundy_button"
            android:gravity="center"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Çıkış Yap"
                android:textStyle="bold"
                android:textColor="@color/text_white"
                android:textSize="16sp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
