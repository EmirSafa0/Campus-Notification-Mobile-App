<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fillViewport="true">

    <!-- Sayfanın ana dikey yerleşimi -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Üst bar: geri butonu ve başlık -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@color/burgundy"
            android:gravity="center_vertical"
            android:padding="16dp">

            <!-- Geri butonu -->
            <TextView
                android:id="@+id/btnBackReport"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Geri"
                android:textColor="@color/text_white"
                android:textSize="16sp" />

            <!-- Sayfa başlığı -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Yeni Bildirim"
                android:textColor="@color/text_white"
                android:textStyle="bold"
                android:textSize="20sp"
                android:gravity="center" />
        </LinearLayout>

        <!-- Bildirim bilgileri için form kartı -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/card_bg"
            android:layout_marginTop="18dp">

            <!-- Bildirim başlığı -->
            <EditText
                android:id="@+id/etReportTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Başlık"
                android:padding="12dp"
                android:background="@android:drawable/edit_text"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary" />

            <!-- Bildirim açıklaması -->
            <EditText
                android:id="@+id/etReportDescription"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:hint="Açıklama"
                android:gravity="top|start"
                android:padding="12dp"
                android:layout_marginTop="12dp"
                android:background="@android:drawable/edit_text"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary" />

            <!-- Bildirim kategorisi seçimi -->
            <Spinner
                android:id="@+id/spReportCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp" />
        </LinearLayout>

        <!-- Harita üzerinden konum seçme alanı -->
        <LinearLayout
            android:id="@+id/btnPickLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/burgundy_button"
            android:padding="14dp"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/txtPickLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Haritada Konum Seç"
                android:textColor="@color/text_white"
                android:textStyle="bold"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Seçilen konum bilgisinin gösterildiği alan -->
        <EditText
            android:id="@+id/etReportLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Seçilen konum buraya gelecek"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:enabled="false"
            android:layout_marginTop="8dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="14sp" />

        <!-- Fotoğraf ekleme butonu -->
        <LinearLayout
            android:id="@+id/btnAttachPhoto"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/burgundy_button"
            android:gravity="center"
            android:padding="10dp"
            android:layout_marginTop="16dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fotoğraf Ekle"
                android:textColor="@color/text_white"
                android:textStyle="bold"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Seçilen fotoğrafın önizlemesi -->
        <ImageView
            android:id="@+id/imgPreview"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="10dp"
            android:scaleType="centerCrop"
            android:background="@color/burgundy_light"
            android:visibility="gone" />

        <!-- Fotoğraf durumu bilgisi -->
        <TextView
            android:id="@+id/txtPhotoStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fotoğraf seçilmedi"
            android:layout_marginTop="6dp"
            android:textColor="@color/text_secondary" />

        <!-- Bildirimi gönderme butonu -->
        <Button
            android:id="@+id/btnSubmitReport"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Bildirimi Gönder"
            android:textColor="@color/text_white"
            android:background="@drawable/burgundy_button"
            android:backgroundTint="@null"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp" />

    </LinearLayout>
</ScrollView>
