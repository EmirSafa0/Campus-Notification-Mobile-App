<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- 🚨 ÜST BAŞLIK -->
        <TextView
            android:id="@+id/txtHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Acil Durumu Düzenle"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/burgundy"
            android:gravity="center"
            android:padding="12dp" />

        <!-- FORM KARTI -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            android:elevation="6dp">

            <!-- BAŞLIK -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Acil Durum Başlığı"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

            <EditText
                android:id="@+id/editTitle"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@android:drawable/edit_text"
                android:hint="Örn: Yangın Alarmı – A Blok"
                android:padding="12dp"
                android:textSize="16sp"
                android:layout_marginBottom="18dp" />

            <!-- AÇIKLAMA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Acil Durum Açıklaması"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

            <EditText
                android:id="@+id/editDescription"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:background="@android:drawable/edit_text"
                android:hint="Acil durumla ilgili detayları buraya yazın..."
                android:gravity="top"
                android:padding="12dp"
                android:textSize="15sp"
                android:layout_marginBottom="24dp" />

            <!-- BUTONLAR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- İPTAL -->
                <TextView
                    android:id="@+id/btnCancel"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="İptal"
                    android:gravity="center"
                    android:textStyle="bold"
                    android:textColor="@color/burgundy"
                    android:background="@color/burgundy_light"
                    android:layout_marginEnd="12dp"
                    android:textSize="16sp" />

                <!-- KAYDET -->
                <TextView
                    android:id="@+id/btnSave"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="Güncelle"
                    android:gravity="center"
                    android:textStyle="bold"
                    android:textColor="@color/text_white"
                    android:background="@drawable/burgundy_button"
                    android:textSize="16sp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
