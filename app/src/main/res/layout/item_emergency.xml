<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    card_view:cardCornerRadius="14dp"
    card_view:cardElevation="6dp"
    card_view:cardUseCompatPadding="true"
    card_view:cardBackgroundColor="#FFF5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- 🔴 KIRMIZI ACİL ŞERİT -->
        <View
            android:layout_width="6dp"
            android:layout_height="match_parent"
            android:background="@color/burgundy"/>

        <!-- İÇERİK -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- BAŞLIK -->
            <TextView
                android:id="@+id/txtTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Yangın Alarmı – A Blok"
                android:textStyle="bold"
                android:textSize="17sp"
                android:textColor="@color/burgundy"
                android:maxLines="2"
                android:ellipsize="end"/>

            <!-- AÇIKLAMA -->
            <TextView
                android:id="@+id/txtDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="A Blok 2. katta yangın alarmı çalmaktadır. Bölgeden uzak durunuz."
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:layout_marginTop="8dp"/>

            <!-- TARİH -->
            <TextView
                android:id="@+id/txtDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="18.12.2025 01:42"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="10dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
