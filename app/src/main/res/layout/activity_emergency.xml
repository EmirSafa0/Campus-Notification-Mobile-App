<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <!-- ================= ÜST BAR ================= -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/burgundy"
        android:gravity="center_vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/btnBackEmergency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Geri"
            android:textColor="@color/text_white"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🚨 Acil Durumlar"
            android:textColor="@color/text_white"
            android:textStyle="bold"
            android:textSize="18sp"
            android:gravity="center" />
    </LinearLayout>

    <!-- ================= BOŞ DURUM ================= -->
    <TextView
        android:id="@+id/txtEmptyEmergency"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Aktif acil durum bulunmuyor."
        android:textSize="15sp"
        android:textColor="@color/text_secondary"
        android:layout_centerInParent="true"
        android:visibility="gone"/>

    <!-- ================= LİSTE ================= -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerEmergency"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/btnBackEmergency"
        android:layout_marginTop="56dp"
        android:paddingBottom="80dp"/>

    <!-- ================= ➕ FAB ================= -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddEmergency"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="18dp"
        android:src="@drawable/ic_add"
        app:tint="@color/text_white"
        app:backgroundTint="@color/burgundy"/>

</RelativeLayout>
