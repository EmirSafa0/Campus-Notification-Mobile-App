<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.KampusBildirimleri" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Arka plan koyu gri -->
        <item name="android:colorBackground">#1B1B1B</item>
        <item name="colorSurface">#1B1B1B</item>
        <item name="colorOnSurface">#FFFFFF</item>

        <!-- Toolbar gece modunda da Burgundy -->
        <item name="colorPrimary">@color/burgundy</item>
        <item name="colorOnPrimary">@color/text_white</item>

        <!-- Material3 default mor davranışını KAPAT -->
        <item name="materialButtonStyle">@style/CustomButtonStyle</item>
        <item name="buttonStyle">@style/CustomButtonStyle</item>
        <item name="android:buttonStyle">@style/CustomButtonStyle</item>

        <!-- Gece ripple mor olmasın -->
        <item name="android:colorControlHighlight">@android:color/transparent</item>
        <item name="colorControlHighlight">@android:color/transparent</item>

    </style>

    <style name="Theme.KampusBildirimleri" parent="Base.Theme.KampusBildirimleri"/>

    <style name="CustomButtonStyle" parent="Widget.Material3.Button">

        <!-- Tint kapalı -->
        <item name="backgroundTint">@null</item>
        <item name="android:backgroundTint">@null</item>

        <!-- Ripple kapalı -->
        <item name="rippleColor">@android:color/transparent</item>

        <!-- Burgundy buton arka planı -->
        <item name="android:background">@drawable/burgundy_button</item>

        <!-- Yazı rengi beyaz -->
        <item name="android:textColor">@android:color/white</item>

        <!-- Büyük harf yok -->
        <item name="android:textAllCaps">false</item>

        <!-- Padding -->
        <item name="android:padding">12dp</item>

    </style>

</resources>
