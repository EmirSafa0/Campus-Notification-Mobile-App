<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Arka Plan (Soft Burgundy Pastel) -->
    <solid android:color="#FFF3F6" />

    <!-- Köşeler -->
    <corners android:radius="14dp"/>

    <!-- İnce Burgundy Kenarlık -->
    <stroke
        android:width="1dp"
        android:color="#B23E57" />

    <!-- İç Boşluk (Tutarlı UI için 12dp) -->
    <padding
        android:left="12dp"
        android:top="12dp"
        android:right="12dp"
        android:bottom="12dp" />

</shape>
