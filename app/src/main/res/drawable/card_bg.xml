<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- BASILI DURUM -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#6D001F"/> <!-- Burgundy Dark -->
            <corners android:radius="14dp"/>
            <stroke android:width="1dp" android:color="#93022E"/> <!-- Burgundy Primary -->
            <padding
                android:left="12dp"
                android:top="12dp"
                android:right="12dp"
                android:bottom="12dp" />
        </shape>
    </item>

    <!-- NORMAL DURUM -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFF3F6"/> <!-- Burgundy Pastel (çok soft) -->
            <corners android:radius="14dp"/>
            <stroke android:width="1dp" android:color="#B23E57"/> <!-- Soft Burgundy Border -->
            <padding
                android:left="12dp"
                android:top="12dp"
                android:right="12dp"
                android:bottom="12dp" />
        </shape>
    </item>

</selector>
